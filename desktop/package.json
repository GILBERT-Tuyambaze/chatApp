{
  "name": "couple-chat-desktop",
  "version": "1.0.0",
  "description": "Electron wrapper for Private Couple Chat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist":  "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.couple.chat",
    "productName": "Us Always",
    "directories": { "output": "dist-electron" },
    "mac":     { "category": "public.app-category.social-networking" },
    "win":     { "target": "nsis" },
    "linux":   { "target": "AppImage" },
    "files": ["main.js", "preload.js", "../frontend/dist/**"]
  }
}
